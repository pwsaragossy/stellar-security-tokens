# Server Configuration
PORT=3000
NODE_ENV=development

# Stellar Network
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org

# Issuer Account (Token LLC)
ISSUER_SECRET_KEY=your_issuer_secret_key_here
ISSUER_PUBLIC_KEY=your_issuer_public_key_here

# Distribution Account
DISTRIBUTOR_SECRET_KEY=your_distributor_secret_key_here
DISTRIBUTOR_PUBLIC_KEY=your_distributor_public_key_here
DISTRIBUTION_SECRET_KEY=your_distribution_secret_key_here
DISTRIBUTION_PUBLIC_KEY=your_distribution_public_key_here

# Treasury Account (recebe USDC dos investidores)
TREASURY_SECRET_KEY=your_treasury_secret_key_here
TREASURY_PUBLIC_KEY=your_treasury_public_key_here

# Token Details
ASSET_CODE=SIN01
ASSET_SUPPLY=1000

# USDC Contract
USDC_ISSUER=GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN

# PostgreSQL Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stellar_tokens
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stellar_tokens

# Security
JWT_SECRET=your_jwt_secret_here_change_in_production
API_KEY=your_api_key_here

# Email Configuration (for interest payment notifications)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key_here
SMTP_FROM=noreply@yourdomain.com
