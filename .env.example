# Server Configuration
PORT=3000
NODE_ENV=development

# Stellar Network
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org

# Issuer Account (Token LLC)
ISSUER_SECRET_KEY=your_issuer_secret_key_here
ISSUER_PUBLIC_KEY=your_issuer_public_key_here

# Distribution Account
DISTRIBUTOR_SECRET_KEY=your_distributor_secret_key_here
DISTRIBUTOR_PUBLIC_KEY=your_distributor_public_key_here
DISTRIBUTION_SECRET_KEY=your_distribution_secret_key_here
DISTRIBUTION_PUBLIC_KEY=your_distribution_public_key_here

# Treasury Account (recebe USDC dos investidores)
TREASURY_SECRET_KEY=your_treasury_secret_key_here
TREASURY_PUBLIC_KEY=your_treasury_public_key_here

# Token Details
ASSET_CODE=SIN01
ASSET_SUPPLY=1000

# USDC Contract
USDC_ISSUER=GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN

# PostgreSQL Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stellar_tokens
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stellar_tokens

# Security
JWT_SECRET=your_jwt_secret_here_change_in_production
API_KEY=your_api_key_here

# Email Configuration (for interest payment notifications)
# OPCIONAL: Deixe desabilitado para desenvolvimento. O sistema funciona normalmente sem email.
# Veja EMAIL_SETUP.md para instruções detalhadas de configuração
# Exemplos de provedores: Gmail, SendGrid, Mailgun, Amazon SES, Outlook
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password_or_api_key
# SMTP_FROM=noreply@yourdomain.com

# Payment Scheduler
ENABLE_AUTO_PAYMENTS=true

# WebAuthn Configuration (Passkey Authentication)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5173

# Stellar Passkey Kit (Smart Wallet)
# Soroban RPC URL for smart contract interactions
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Launchtube - Transaction sponsorship service
# Get JWT from Stellar Discord #launchtube channel
LAUNCHTUBE_URL=https://launchtube.xyz
LAUNCHTUBE_JWT=your_launchtube_jwt_here

# Factory Contract ID - Smart wallet factory (Testnet)
# This is the official Stellar smart wallet factory contract
FACTORY_CONTRACT_ID=CBKZRF5QVDPXFBPWGUBIHXUJGYJFSCNRLMHKD2FNMKQH2HYBBKPINNEX

# Email Verification
EMAIL_VERIFICATION_EXPIRY_HOURS=24
FRONTEND_URL=http://localhost:5173
