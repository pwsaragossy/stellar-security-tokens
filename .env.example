# ===========================================
# DEVELOPMENT ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in values
# ===========================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Stellar Network Configuration
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Issuer Account (Token LLC)
# Generate with: node -e "const {Keypair}=require('@stellar/stellar-sdk');const k=Keypair.random();console.log('SECRET='+k.secret()+'\nPUBLIC='+k.publicKey())"
ISSUER_SECRET_KEY=your_issuer_secret_key_here
ISSUER_PUBLIC_KEY=your_issuer_public_key_here

# Distribution Account
DISTRIBUTOR_SECRET_KEY=your_distributor_secret_key_here
DISTRIBUTOR_PUBLIC_KEY=your_distributor_public_key_here

# Treasury Account (receives USDC from investors)
TREASURY_SECRET_KEY=your_treasury_secret_key_here
TREASURY_PUBLIC_KEY=your_treasury_public_key_here

# Token Details
# NOTE: ASSET_CODE is deprecated - each offer defines its own asset code
# ASSET_CODE=SIN01 (removed - use offer-specific asset codes)

# USDC Contract (Circle Issuer - same for testnet and mainnet)
USDC_ISSUER=GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN

# PostgreSQL Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stellar_tokens
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stellar_tokens

# Security
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here
API_KEY=your_api_key_here
API_URL=http://localhost:3000

# Redis (for rate limiting - optional, uses memory store if not available)
REDIS_HOST=localhost

# Email Configuration (optional for development)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=noreply@yourdomain.com

# Payment Scheduler
ENABLE_AUTO_PAYMENTS=true

# WebAuthn Configuration (Passkey Authentication)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5173

# Launchtube - Transaction sponsorship service
# Get JWT from Stellar Discord #launchtube channel
LAUNCHTUBE_URL=https://launchtube.xyz
LAUNCHTUBE_JWT=your_launchtube_jwt_here

# Factory Contract ID - Smart wallet factory (Testnet)
FACTORY_CONTRACT_ID=CBKZRF5QVDPXFBPWGUBIHXUJGYJFSCNRLMHKD2FNMKQH2HYBBKPINNEX

# Email Verification & CORS
EMAIL_VERIFICATION_EXPIRY_HOURS=24
FRONTEND_URL=http://localhost:5173

# Pinata IPFS Configuration
# Get from https://app.pinata.cloud/
PINATA_JWT=your_pinata_jwt_here
