# =============================================================================
# ENVIRONMENT TEMPLATE
# =============================================================================
# Copy this file and rename it:
#   .env            → For dev (Docker Compose loads this automatically)
#   .env.production → For mainnet deployment (no secret keys, multisig only)
#
# Usage:
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d
#   With Cloudflare tunnel: same compose files plus --profile cf-tunnel (after cloudflared login)
#   docker compose --env-file .env.production -f docker-compose.prod.yml up
#
# Optional (docker-compose.dev.yml): tunnel profile mounts ~/.cloudflared (or CLOUDFLARED_CONFIG_DIR).
# After `cloudflared login`, cert is usually ~/.cloudflared/cert.pem. If compose does not
# expand $HOME in defaults on your system, set explicitly:
# CLOUDFLARED_CONFIG_DIR=/home/youruser/.cloudflared
#
# NOTE: DB_HOST, DATABASE_URL, REDIS_HOST are hardcoded in docker-compose.yml
# for Docker runs. Values here are only used for non-Docker local runs.
# =============================================================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Key Management Mode
# 'multisig' = Freighter/Ledger signing (no secret keys needed)
# 'env'      = Server-side signing with secret keys (tests only)
KEY_MANAGEMENT_MODE=multisig

# Stellar Network Configuration
# Testnet:
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# Mainnet (uncomment for production):
# STELLAR_NETWORK=public
# STELLAR_HORIZON_URL=https://horizon.stellar.org
# HORIZON_URL=https://horizon.stellar.org
# SOROBAN_RPC_URL=https://soroban-rpc.mainnet.stellar.gateway.fm
# SOROBAN_RPC_API_KEY=              # Optional — sent as X-API-Key to RPC provider
# SOROBAN_RPC_HEADER=               # Optional — arbitrary header, e.g. "X-Custom: value"

# Home domain for stellar.toml (must match issuer account on-chain)
STELLAR_HOME_DOMAIN=

# Stellar Accounts — PUBLIC KEYS (always required)
ISSUER_PUBLIC_KEY=
DISTRIBUTOR_PUBLIC_KEY=
OPERATIONS_PUBLIC_KEY=
TREASURY_PUBLIC_KEY=

# Stellar Accounts — SECRET KEYS (only when KEY_MANAGEMENT_MODE=env)
# Leave empty/remove for multisig mode
ISSUER_SECRET_KEY=
DISTRIBUTOR_SECRET_KEY=
# In production: use Docker Secrets instead (see docker-compose.prod.yml)
# echo 'SXXXX...' > /root/.secrets/operations_key && chmod 600 /root/.secrets/operations_key
OPERATIONS_SECRET_KEY=
TREASURY_SECRET_KEY=

# Channel Accounts Pool — Parallel Fee Sponsorship (optional)
# Prevents tx_bad_seq errors during concurrent operations.
# Each channel account needs ~2 XLM on-chain.
# If none defined, Operations wallet is used as a single channel (serialized).
# Generate with: node -e "console.log(require('@stellar/stellar-sdk').Keypair.random().secret())"
# CHANNEL_1_SECRET_KEY=
# CHANNEL_2_SECRET_KEY=
# CHANNEL_3_SECRET_KEY=
# CHANNEL_4_SECRET_KEY=
# CHANNEL_5_SECRET_KEY=

# USDC Issuer - Leave empty for auto-detection based on STELLAR_NETWORK
# Testnet: GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
# Mainnet: GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
# USDC_ISSUER=

# PostgreSQL Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stellar_tokens
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stellar_tokens

# Security
# Generate with: openssl rand -hex 32
JWT_SECRET=
API_KEY=
API_URL=http://localhost:3000

# Redis (for rate limiting - optional, uses memory store if not available)
REDIS_HOST=localhost
REDIS_PASSWORD=

# Email Configuration (Resend HTTP API)
# Get your API key at https://resend.com — leave empty for dev mode (console logging)
RESEND_API_KEY=
EMAIL_FROM=Radox <noreply@mail.radox.net>

# Payment Scheduler
ENABLE_AUTO_PAYMENTS=true

# WebAuthn Configuration (Passkey Authentication)
# RP_ID = root domain (allows subdomains to share passkeys)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5173

# Frontend URL (for CORS, emails, redirects)
FRONTEND_URL=http://localhost:5173

# OpenZeppelin Stellar Channels - Fee-sponsored transaction submission
CHANNELS_API_KEY=

# OZ Smart Account Configuration
ACCOUNT_WASM_HASH=
WEBAUTHN_VERIFIER_ADDRESS=
ED25519_VERIFIER_ADDRESS=

# Email Verification
EMAIL_VERIFICATION_EXPIRY_HOURS=24

# Pinata IPFS Configuration
PINATA_JWT=

# Soroban Asset Contract IDs for balance queries
# Native XLM SAC on Testnet (deterministic)
XLM_SAC_CONTRACT_ID=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC
# USDC SAC on Testnet
USDC_SAC_CONTRACT_ID=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA

# Test Accounts (used by test scripts with stellar_tokens_test database)
TEST_INVESTOR_SECRET_KEY=
TEST_INVESTOR_PUBLIC_KEY=
TEST_COMPANY_SECRET_KEY=
TEST_COMPANY_PUBLIC_KEY=

# Pusher Configuration (Real-Time Sync)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
PUSHER_USE_TLS=true

# Admin Bootstrapping
ADMIN_1_EMAIL=
ADMIN_1_NAME=
ADMIN_2_EMAIL=
ADMIN_2_NAME=

# Soroban Contract Integration
# Set to 'true' to enable Soroban sale contracts, event indexer, and reconciler
ENABLE_SOROBAN_SALE=false
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Yield Distributor Contract (batched periodic payments)
YIELD_DISTRIBUTOR_CONTRACT_ID=

# Alert Routing (optional — omit to use DB-only notifications)
ALERT_SLACK_WEBHOOK_URL=
ALERT_PAGERDUTY_ROUTING_KEY=

# Operations Wallet Monitor
# Email address to receive alerts when the Operations wallet balance is low.
# Leave empty to disable email alerts (log-only mode).
ADMIN_ALERT_EMAIL=

# XLM balance thresholds for the Operations wallet:
#   WARNING  — log.warn + one-time email alert
#   CRITICAL — log.error + urgent email alert + purchases blocked (503)
# Defaults are conservative for pilot launch (20 / 5 XLM).
OPERATIONS_WALLET_WARNING_XLM=20
OPERATIONS_WALLET_CRITICAL_XLM=5

# =============================================================================
# EtherFuse Anchor — BRL/PIX on-ramp → TESOURO (Stellar BR accelerator)
# =============================================================================
# Docs:       docs.etherfuse.com (MCP available at /mcp)
# Sandbox:    https://api.sand.etherfuse.com  (devnet UI: https://devnet.etherfuse.com)
# Production: https://api.etherfuse.com
# Auth:       Authorization: <api_key> header — NO "Bearer" prefix
# Account:    Must be "business" type to access the API
# Asset:      On-ramp delivers TESOURO (BRL-pegged yield-bearing stablebond),
#             NOT USDC. To get USDC, swap TESOURO → USDC via Soroswap after delivery.

# Feature flag — keep false until the sandbox probe validates Path A (direct C-address
# delivery) vs Path C (per-investor G-address ramp with custodial keys).
ENABLE_ETHERFUSE_ANCHOR=false

# API config
ETHERFUSE_API_BASE_URL=https://api.sand.etherfuse.com
ETHERFUSE_API_KEY=

# Filled in after first run / probe:
#   ETHERFUSE_ORG_ID                    — from GET /ramp/me
#   ETHERFUSE_WEBHOOK_SECRET            — returned by POST /ramp/webhook on first registration
#   ETHERFUSE_TESOURO_ASSET_IDENTIFIER  — CODE:ISSUER, pinned from GET /ramp/assets
ETHERFUSE_ORG_ID=
ETHERFUSE_WEBHOOK_SECRET=
ETHERFUSE_TESOURO_ASSET_IDENTIFIER=
