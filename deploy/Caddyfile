# =============================================================================
# Caddy Reverse Proxy Configuration
# =============================================================================
# Auto-HTTPS for all domains via Let's Encrypt.
# DNS records must point to the VM IP (Cloudflare: DNS only / grey cloud).
# =============================================================================

# Landing page — static files + stellar.toml from backend
radox.net {
    # SEP-1: stellar.toml MUST be served by backend (dynamic, DB-driven)
    handle /.well-known/* {
        reverse_proxy backend:3000
    }

    # Everything else → static landing page
    handle {
        root * /srv/landing
        file_server
        try_files {path} /index.html
    }
}

# Dev domain — serves stellar.toml for dev issuer account (SEP-1)
dev.radox.net {
    handle /.well-known/* {
        reverse_proxy backend:3000
    }

    # Fallback: redirect to main landing page
    handle {
        redir https://radox.net{uri} permanent
    }
}

# Frontend app — React SPA served by nginx
app.radox.net {
    reverse_proxy frontend:80
}

# Backend API — direct access for Swagger, monitoring, future mobile apps
api.radox.net {
    reverse_proxy backend:3000
}

# www redirect — sends www.radox.net to radox.net
www.radox.net {
    redir https://radox.net{uri} permanent
}
