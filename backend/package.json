{
  "name": "stellar-security-tokens",
  "version": "1.0.0",
  "description": "API REST para tokenização de security tokens no Stellar",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node --import tsx src/index.js",
    "dev": "node --watch --import tsx src/index.js",
    "bootstrap-admins": "node ../scripts/bootstrap-admins.js",
    "prisma:generate": "dotenv -e ../.env -- prisma generate",
    "prisma:studio": "dotenv -e ../.env -- prisma studio",
    "prisma:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "prisma:migrate:deploy": "dotenv -e ../.env -- prisma migrate deploy",
    "prisma:db:pull": "dotenv -e ../.env -- prisma db pull",
    "migrate": "dotenv -e ../.env -- prisma migrate deploy",
    "migrate:dev": "dotenv -e ../.env -- prisma migrate dev",
    "setup": "node ../scripts/setup.js",
    "test": "sh -c 'test -f ../.env && . ../.env; NODE_ENV=test DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stellar_tokens_test npm run test:unit && npm run test:integration'",
    "test:unit": "sh -c 'test -f ../.env && . ../.env; NODE_ENV=test DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stellar_tokens_test find tests/unit/ -name \"*.test.js\" ! -name \"*integration*\" -exec node --import tsx --test {} \\;'",
    "test:unit:all": "sh -c 'test -f ../.env && . ../.env; NODE_ENV=test DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stellar_tokens_test node --experimental-test-module-mocks --import tsx --test tests/unit/**/*.test.js'",
    "test:integration": "sh -c 'test -f ../.env && . ../.env; NODE_ENV=test DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stellar_tokens_test node --import tsx --test --test-force-exit --test-concurrency=1 tests/integration/**/*.test.js'",
    "test:ci": "sh -c 'test -f ../.env && . ../.env; NODE_ENV=test DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stellar_tokens_test npx prisma migrate deploy && node --experimental-test-module-mocks --import tsx --test --test-concurrency=1 tests/unit/**/*.test.js tests/integration/**/*.mocked.test.js'",
    "test:watch": "node --watch --test",
    "test:email": "node ../scripts/test-email.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:dev": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "docker:dev:build": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "docker:dev:down": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.{js,json}\" \"tests/**/*.{js,json}\"",
    "multisig:inspect": "node --import tsx scripts/inspect-accounts.js",
    "multisig:setup": "node --import tsx scripts/setup-multisig.js",
    "test:e2e:lifecycle": "sh -c 'test -f ../.env && . ../.env; NODE_ENV=development STELLAR_NETWORK=testnet node --import tsx tests/e2e/tokenLifecycle.test.js'",
    "test:e2e:contracts": "STELLAR_NETWORK=testnet node --import tsx tests/e2e/contractManagement.test.js",
    "audit:security": "npm audit --audit-level=high"
  },
  "keywords": [
    "stellar",
    "security-tokens",
    "blockchain",
    "tokenization"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@openzeppelin/relayer-plugin-channels": "^0.17.0",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.6.0",
    "@sentry/node": "^10.34.0",
    "@simplewebauthn/browser": "^13.2.2",
    "@simplewebauthn/server": "^13.2.2",
    "@stellar/stellar-sdk": "^14.6.0",
    "axios": "1.13.6",
    "bcrypt": "^6.0.0",
    "bull": "^4.12.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.0.1",
    "form-data": "^4.0.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.4",
    "pg": "^8.11.3",
    "pinata-web3": "^0.5.4",
    "pusher": "^5.3.2",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.10.0",
    "resend": "^6.9.3",
    "smart-account-kit": "^0.2.10",
    "smart-account-kit-bindings": "^0.1.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "esmock": "^2.7.3",
    "nodemon": "^3.0.2",
    "prettier": "^3.2.5",
    "prisma": "^7.6.0",
    "supertest": "^7.1.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
