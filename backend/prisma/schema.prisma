// ============================================
// ETHERFUSE ANCHOR: BRL/PIX ↔ TESOURO/USDC ramps
// (on-ramp models below; off-ramp models reuse Quote/Order and add the
//  per-investor relayer wallet at the end of this section)
// ============================================

// Per-investor EtherFuse customer (child organization).
// Created on first on-ramp KYC submission. The `etherfuseCustomerId` is the
// UUID we generate locally and pass to EtherFuse via POST /ramp/organization;
// it doubles as the customerId field on quotes and orders.
model RampCustomer {
  id                  Int                 @id @default(autoincrement())
  investorId          Int                 @unique @map("investor_id")
  etherfuseCustomerId String              @unique @map("etherfuse_customer_id") @db.Uuid
  accountType         String              @default("personal") @map("account_type") @db.VarChar(20) // personal | business
  kycStatus           RampWalletKycStatus @default(not_started) @map("kyc_status")
  kycRejectionReason  String?             @map("kyc_rejection_reason") @db.Text
  lastSyncedAt        DateTime?           @map("last_synced_at") @db.Timestamp
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamp
  updatedAt           DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamp

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@index([etherfuseCustomerId])
  @@index([kycStatus])
  @@map("ramp_customers")
}

// Per-investor wallet registered with EtherFuse.
// `publicKey` is whatever address EtherFuse holds for delivery — for Path A
// this is the Soroban C-address; for Path C this is a custodial G-address.
// EtherFuse enforces 1:1 binding between (publicKey, customerId).
model RampWallet {
  id                Int                 @id @default(autoincrement())
  investorId        Int                 @map("investor_id")
  etherfuseWalletId String              @unique @map("etherfuse_wallet_id") @db.Uuid
  publicKey         String              @map("public_key") @db.VarChar(64)
  blockchain        String              @default("stellar") @db.VarChar(20)
  kycStatus         RampWalletKycStatus @default(not_started) @map("kyc_status")
  claimedOwnership  Boolean             @default(false) @map("claimed_ownership")
  isAuthenticated   Boolean             @default(false) @map("is_authenticated")
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamp
  updatedAt         DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamp

  investor Investor    @relation(fields: [investorId], references: [id], onDelete: Cascade)
  orders   RampOrder[]

  @@unique([investorId, publicKey])
  @@index([publicKey])
  @@index([kycStatus])
  @@map("ramp_wallets")
}

// EtherFuse bank account record — BR/PIX. Stored locally for display but
// authoritative state lives at EtherFuse and is mirrored via webhooks.
// PIX-specific fields (pixKey, pixKeyType) are kept nullable for forward
// compatibility with the MX flow (CLABE-based) — the active flow for Radox
// is BR/PIX. Probe the sandbox to confirm exact wire field names before
// shipping; the EtherFuse public docs are MX-centric and stale on BR.
model RampBankAccount {
  id                     Int                   @id @default(autoincrement())
  investorId             Int                   @map("investor_id")
  etherfuseBankAccountId String                @unique @map("etherfuse_bank_account_id") @db.Uuid
  label                  String?               @db.VarChar(120)
  pixKey                 String?               @map("pix_key") @db.VarChar(255)
  pixKeyType             String?               @map("pix_key_type") @db.VarChar(20) // cpf | cnpj | email | phone | evp
  abbrPixKey             String?               @map("abbr_pix_key") @db.VarChar(64) // last-4 / abbreviated for UI
  status                 RampBankAccountStatus @default(pending)
  isDefault              Boolean               @default(false) @map("is_default")
  deletedAt              DateTime?             @map("deleted_at") @db.Timestamp
  createdAt              DateTime              @default(now()) @map("created_at") @db.Timestamp
  updatedAt              DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamp

  investor Investor    @relation(fields: [investorId], references: [id], onDelete: Cascade)
  orders   RampOrder[]

  @@index([investorId, deletedAt])
  @@index([status])
  @@map("ramp_bank_accounts")
}

// Short-lived quote cache. EtherFuse quotes expire after 2 minutes; we keep
// the row for audit and reconciliation. `etherfuseQuoteId` is the UUID we
// generate and pass to POST /ramp/quote.
model RampQuote {
  id                Int           @id @default(autoincrement())
  investorId        Int           @map("investor_id")
  etherfuseQuoteId  String        @unique @map("etherfuse_quote_id") @db.Uuid
  orderType         RampOrderType @map("order_type")
  blockchain        String        @default("stellar") @db.VarChar(20)
  sourceAsset       String        @map("source_asset") @db.VarChar(120) // "BRL" or "USDC:G..."
  targetAsset       String        @map("target_asset") @db.VarChar(120)
  sourceAmount      Decimal       @map("source_amount") @db.Decimal(20, 7)
  destinationAmount Decimal?      @map("destination_amount") @db.Decimal(20, 7)
  feeBps            Int?          @map("fee_bps")
  feeAmount         Decimal?      @map("fee_amount") @db.Decimal(20, 7)
  exchangeRate      String?       @map("exchange_rate") @db.VarChar(64) // string preserves precision
  walletAddress     String?       @map("wallet_address") @db.VarChar(64)
  expiresAt         DateTime      @map("expires_at") @db.Timestamp
  rawResponse       Json?         @map("raw_response")
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamp

  investor Investor    @relation(fields: [investorId], references: [id], onDelete: Cascade)
  orders   RampOrder[]

  @@index([investorId, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@map("ramp_quotes")
}

// Materialized ramp order. State machine is driven by `order_updated`
// webhook events; the reconciler fills gaps if webhooks are missed.
// `pixInstructions` (JSONB) holds whatever EtherFuse returns for the BR/PIX
// flow — exact shape discovered empirically during the sandbox probe.
model RampOrder {
  id               Int    @id @default(autoincrement())
  investorId       Int    @map("investor_id")
  etherfuseOrderId String @unique @map("etherfuse_order_id") @db.Uuid
  quoteId          Int    @map("quote_id")
  walletId         Int    @map("wallet_id")
  bankAccountId    Int    @map("bank_account_id")

  orderType      RampOrderType   @map("order_type")
  status         RampOrderStatus @default(created)
  amountInFiat   Decimal?        @map("amount_in_fiat") @db.Decimal(20, 7)
  amountInTokens Decimal?        @map("amount_in_tokens") @db.Decimal(20, 7)
  sourceAsset    String?         @map("source_asset") @db.VarChar(120)
  targetAsset    String?         @map("target_asset") @db.VarChar(120)

  // On-ramp PIX deposit instructions (returned from POST /ramp/order).
  // Stored as JSONB so the BR-specific fields can be added without migrations.
  pixInstructions Json?     @map("pix_instructions")
  pixExpiresAt    DateTime? @map("pix_expires_at") @db.Timestamp

  // Final delivery
  confirmedTxSignature      String? @map("confirmed_tx_signature") @db.VarChar(128)
  stellarClaimableBalanceId String? @map("stellar_claimable_balance_id") @db.VarChar(80)
  stellarClaimTransaction   String? @map("stellar_claim_transaction") @db.Text

  // Off-ramp anchor mode (Phase 2 — fields reserved so the schema doesn't
  // churn when off-ramp lands)
  burnTransaction       String? @map("burn_transaction") @db.Text
  withdrawAnchorAccount String? @map("withdraw_anchor_account") @db.VarChar(64)
  withdrawMemo          String? @map("withdraw_memo") @db.VarChar(128)
  withdrawMemoType      String? @map("withdraw_memo_type") @db.VarChar(16)

  statusPage    String? @map("status_page") @db.VarChar(512)
  failureReason String? @map("failure_reason") @db.Text

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp
  fundedAt    DateTime? @map("funded_at") @db.Timestamp
  completedAt DateTime? @map("completed_at") @db.Timestamp

  investor    Investor        @relation(fields: [investorId], references: [id], onDelete: Cascade)
  quote       RampQuote       @relation(fields: [quoteId], references: [id])
  wallet      RampWallet      @relation(fields: [walletId], references: [id])
  bankAccount RampBankAccount @relation(fields: [bankAccountId], references: [id])

  @@index([investorId, createdAt(sort: Desc)])
  @@index([status])
  @@index([orderType, status])
  @@index([pixExpiresAt])
  @@map("ramp_orders")
}

// Idempotency log + audit trail for incoming EtherFuse webhooks. The unique
// constraint on (eventType, resourceId, resourceStatus) means delivery
// retries for the same state transition are deduped at the DB layer.
//
// EtherFuse does NOT publish an event_id header; the resource state is the
// idempotency anchor. State machine in rampOrder.service.js rejects backward
// transitions, so out-of-order deliveries are safely idempotent.
model RampWebhookEvent {
  id              Int       @id @default(autoincrement())
  eventType       String    @map("event_type") @db.VarChar(40) // order_updated, customer_updated, ...
  resourceId      String    @map("resource_id") @db.VarChar(64) // orderId, customerId, bankAccountId, walletId
  resourceStatus  String    @map("resource_status") @db.VarChar(40)
  payloadHash     String    @map("payload_hash") @db.VarChar(64) // sha256 of canonicalized body
  payload         Json
  signatureValid  Boolean   @map("signature_valid")
  processedAt     DateTime? @map("processed_at") @db.Timestamp
  processingError String?   @map("processing_error") @db.Text
  receivedAt      DateTime  @default(now()) @map("received_at") @db.Timestamp

  @@unique([eventType, resourceId, resourceStatus])
  @@index([resourceId])
  @@index([receivedAt])
  @@map("ramp_webhook_events")
}

// Per-investor classic Stellar G-account used as the relayer hop in the
// off-ramp two-TX bridge:
//   TX 1: investor C-address SAC.transfer → this G  (passkey-signed)
//   TX 2: this G classic payment → EtherFuse anchor (this G signs, with the
//         keypair we recover by decrypting `encryptedSeed`)
//
// The keypair is generated server-side at first-off-ramp time, the seed is
// encrypted with AES-256-GCM using OFFRAMP_KEYRING_SECRET, and the public key
// is funded + has trustlines established via a sponsored multi-op TX.
// Key rotation and recovery are handled out-of-band via the operator runbook.
//
// `encryptionVersion` allows future re-keying (e.g. v2 = KMS-managed envelope
// encryption). Migration script reads version, decrypts under the old scheme,
// re-encrypts under the new, and bumps the version.
model InvestorRelayerWallet {
  id                    Int      @id @default(autoincrement())
  investorId            Int      @unique @map("investor_id")
  publicKey             String   @unique @map("public_key") @db.VarChar(56) // G-address
  encryptedSeed         String   @map("encrypted_seed") @db.Text // base64(IV || authTag || ciphertext)
  encryptionVersion     Int      @default(1) @map("encryption_version")
  trustlinesEstablished Boolean  @default(false) @map("trustlines_established")
  provisioningTxHash    String?  @map("provisioning_tx_hash") @db.VarChar(64)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamp
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp

  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@index([publicKey])
  @@map("investor_relayer_wallets")
}
