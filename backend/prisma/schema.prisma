// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum KYCStatus {
  pending
  approved
  rejected
}

enum CompanyStatus {
  pending
  approved
  suspended
  rejected
}

enum OfferStatus {
  pending_review
  under_review
  approved
  rejected
  active
  paused // Emergency pause by admin
  closed
  matured // Bullet offer reached maturity, awaiting company payment
}

enum PaymentType {
  monthly
  bullet
  quarterly
  semi_annual
  annual
}

enum OfferType {
  collateral
  sale
}

enum PaymentStatus {
  pending
  completed
  failed
}

enum PaymentDueStatus {
  current // Payments up to date
  upcoming // Payment due within 30 days
  due // Payment due today
  overdue // Past due but within grace period
  defaulted // Past grace period, collateral liquidated
}

enum InvestmentStatus {
  pending_payment
  trade_submitted // Soroban trade() TX sent, awaiting confirmation
  payment_received
  pending_distribution
  distributed
  failed
  cancelled
}

enum DepositStatus {
  pending // Awaiting payment
  received // USDC received at treasury
  forwarding // SAC transfer in progress
  pending_approval // Awaiting multisig admin approval
  completed // USDC in user's wallet
  expired // Memo expired (24h timeout)
  failed // SAC transfer failed
  rejected // Multisig relay rejected by admin
}

// EtherFuse anchor — fiat ramp order status. Matches the wire-level enum
// returned by EtherFuse webhooks (`status` inside `order_updated` payload).
// `expired` is local-only — emitted by our reconciler when an on-ramp PIX
// instruction passes its TTL without `funded`.
enum RampOrderStatus {
  created
  funded
  completed
  finalized // off-ramp only: reversal window passed
  failed
  refunded
  canceled
  expired // local-only
}

enum RampOrderType {
  onramp
  offramp
}

// EtherFuse bank-account verification status. Mirrors EtherFuse's
// `bank_account_updated` payload `status` field.
enum RampBankAccountStatus {
  pending
  awaiting_deposit_verification
  active
  inactive
}

// Per-wallet KYC status on EtherFuse. Mirrors `kyc_updated` payload statuses.
// `approved_chain_deploying` is Solana-only; left in for completeness.
enum RampWalletKycStatus {
  not_started
  proposed
  approved
  approved_chain_deploying
  rejected
}

enum AssetStage {
  under_development // Planning or construction phase
  completed // Built/ready, not yet income-generating
  income_producing // Active rental/lease/yield
}

// ============================================
// CORE MODELS
// ============================================

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum CompanyUserRole {
  user
  admin
}

enum PlatformAdminRole {
  admin
  manager
  super_admin
}

// Models
model Investor {
  id       Int    @id @default(autoincrement())
  name     String @db.VarChar(255)
  email    String @unique @db.VarChar(255)
  document String @unique @db.VarChar(100)

  kycStatus    KYCStatus @default(pending) @map("kyc_status")
  passwordHash String?   @map("password_hash") @db.VarChar(255)
  lastLogin    DateTime? @map("last_login") @db.Timestamp
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp

  // Smart Wallet (Passkey Kit) fields - REQUIRED for all new investors
  stellarContractId   String  @map("stellar_contract_id") @db.VarChar(56)
  passkeyCredentialId String  @map("passkey_credential_id") @db.Text
  passkeyPublicKey    Bytes?  @map("passkey_public_key")
  passkeyEcosystem    String? @map("passkey_ecosystem") @db.VarChar(20) // apple, google, windows_local, other

  // Email verification fields
  emailVerified           Boolean   @default(false) @map("email_verified")
  emailVerificationToken  String?   @map("email_verification_token") @db.VarChar(64)
  emailVerificationExpiry DateTime? @map("email_verification_expiry") @db.Timestamp

  // Extended KYC — required by the EtherFuse anchor for fiat ramps.
  // Captured via /investor/ramp-kyc before first on-ramp, then pushed to
  // EtherFuse via POST /ramp/customer/{id}/kyc.
  givenName    String?   @map("given_name") @db.VarChar(120)
  familyName   String?   @map("family_name") @db.VarChar(120)
  dateOfBirth  DateTime? @map("date_of_birth") @db.Date
  phone        String?   @db.VarChar(32)
  occupation   String?   @db.VarChar(120)
  addressLine1 String?   @map("address_line1") @db.VarChar(255)
  addressLine2 String?   @map("address_line2") @db.VarChar(255)
  city         String?   @db.VarChar(120)
  region       String?   @db.VarChar(120) // BR state code (UF) or free-text region
  postalCode   String?   @map("postal_code") @db.VarChar(20)
  country      String?   @default("BR") @db.VarChar(2)

  // audit follow-up: per-investor daily cap. NULL = no cap (back-compat).
  // Enforced by middleware/dailyCapCheck.js on fund-moving routes. Set via
  // platform admin endpoint PATCH /api/admin/investors/:id.
  dailyCapUsd Decimal? @map("daily_cap_usd") @db.Decimal(20, 2)

  // Relations
  tokenDistributions  TokenDistribution[]
  interestPayments    InterestPayment[]
  investments         Investment[]
  deposits            Deposit[]
  webauthnCredentials InvestorWebauthnCredential[]
  ed25519Signers      InvestorEd25519Signer[]
  rampCustomer        RampCustomer?
  rampWallets         RampWallet[]
  rampBankAccounts    RampBankAccount[]
  rampQuotes          RampQuote[]
  rampOrders          RampOrder[]
  offrampRelayer      InvestorRelayerWallet?

  @@index([email])
  @@index([document])
  @@index([stellarContractId])
  @@index([emailVerified])
  @@index([kycStatus, createdAt(sort: Desc)])
  @@map("investors")
}

model Token {
  id                      Int      @id @default(autoincrement())
  assetCode               String   @unique @map("asset_code") @db.VarChar(12)
  issuerPublicKey         String   @map("issuer_public_key") @db.VarChar(56)
  totalSupply             Decimal  @map("total_supply") @db.Decimal(20, 7)
  description             String?  @db.Text
  annualInterestRate      Decimal? @default(10.0) @map("annual_interest_rate") @db.Decimal(10, 7)
  offerId                 Int?     @map("offer_id")
  issuedBy                Int?     @map("issued_by")
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamp
  updatedAt               DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp
  sacContractId           String?  @map("sac_contract_id") @db.VarChar(56)
  issuanceTransactionHash String?  @map("issuance_transaction_hash") @db.VarChar(64)

  // Relations
  offer            Offer?              @relation(fields: [offerId], references: [id], onDelete: SetNull)
  issuer           PlatformAdmin?      @relation(fields: [issuedBy], references: [id], onDelete: SetNull)
  distributions    TokenDistribution[]
  interestPayments InterestPayment[]
  investments      Investment[]

  @@index([assetCode])
  @@index([offerId])
  @@index([issuedBy])
  @@map("tokens")
}

model TokenDistribution {
  id              Int            @id @default(autoincrement())
  investorId      Int            @map("investor_id")
  assetCode       String         @map("asset_code") @db.VarChar(12)
  amount          Decimal        @db.Decimal(20, 7)
  transactionHash String         @map("transaction_hash") @db.VarChar(64)
  usdcPaymentHash String?        @map("usdc_payment_hash") @db.VarChar(64)
  offerId         Int?           @map("offer_id")
  memo            String?        @db.VarChar(28)
  approvalStatus  ApprovalStatus @default(pending) @map("approval_status")
  approvedBy      Int?           @map("approved_by")
  approvedAt      DateTime?      @map("approved_at") @db.Timestamp
  approvalNotes   String?        @map("approval_notes") @db.Text
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamp

  // Relations
  investor Investor       @relation(fields: [investorId], references: [id], onDelete: Cascade)
  token    Token          @relation(fields: [assetCode], references: [assetCode], onDelete: Cascade)
  offer    Offer?         @relation(fields: [offerId], references: [id], onDelete: SetNull)
  approver PlatformAdmin? @relation(fields: [approvedBy], references: [id], onDelete: SetNull)

  @@unique([transactionHash])
  @@unique([investorId, assetCode, usdcPaymentHash])
  @@index([investorId])
  @@index([assetCode])
  @@index([transactionHash])
  @@index([usdcPaymentHash])
  @@index([offerId])
  @@index([investorId, assetCode, createdAt(sort: Desc)])
  @@index([approvalStatus])
  @@index([approvedBy])
  @@map("token_distributions")
}

model InterestPayment {
  id                Int           @id @default(autoincrement())
  investorId        Int           @map("investor_id")
  assetCode         String        @map("asset_code") @db.VarChar(12)
  tokenBalance      Decimal       @map("token_balance") @db.Decimal(20, 7)
  interestRate      Decimal       @map("interest_rate") @db.Decimal(10, 7)
  interestAmount    Decimal       @map("interest_amount") @db.Decimal(20, 7)
  usdcAmount        Decimal       @map("usdc_amount") @db.Decimal(20, 7)
  transactionHash   String        @map("transaction_hash") @db.VarChar(64)
  paymentDate       DateTime      @map("payment_date") @db.Date
  emailSent         Boolean       @default(false) @map("email_sent")
  emailSentAt       DateTime?     @map("email_sent_at") @db.Timestamp
  retryCount        Int           @default(0) @map("retry_count")
  status            PaymentStatus @default(pending)
  errorMessage      String?       @map("error_message") @db.Text
  offerId           Int?          @map("offer_id")
  paymentType       PaymentType   @default(monthly) @map("payment_type")
  isBulletPayment   Boolean       @default(false) @map("is_bullet_payment")
  grossAmount       Decimal?      @map("gross_amount") @db.Decimal(20, 7) // Pre-fee amount owed to investor
  netAmount         Decimal?      @map("net_amount") @db.Decimal(20, 7) // Post-fee amount investor received on-chain
  platformFeeAmount Decimal?      @map("platform_fee_amount") @db.Decimal(20, 7) // Platform's cut (grossAmount - netAmount)
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamp

  // Relations
  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)
  token    Token    @relation(fields: [assetCode], references: [assetCode], onDelete: Cascade)
  offer    Offer?   @relation(fields: [offerId], references: [id], onDelete: SetNull)

  @@unique([investorId, assetCode, paymentDate, transactionHash])
  @@index([investorId])
  @@index([assetCode])
  @@index([paymentDate])
  @@index([status])
  @@index([offerId])
  @@index([investorId, assetCode, paymentDate(sort: Desc)])
  @@index([investorId, paymentDate])
  @@index([paymentDate(sort: Desc), assetCode])
  @@index([paymentType])
  @@map("interest_payments")
}

model Company {
  id                  Int           @id @default(autoincrement())
  name                String        @db.VarChar(255)
  cnpj                String?       @unique @db.VarChar(18) // Optional - collected during KYC
  email               String        @unique @db.VarChar(255)
  emailVerified       Boolean       @default(false) @map("email_verified")
  legalRepresentative String?       @map("legal_representative") @db.VarChar(255) // Optional - collected during KYC
  address             String?       @db.Text
  phone               String?       @db.VarChar(20)
  status              CompanyStatus @default(pending)
  kycStatus           KYCStatus     @default(pending) @map("kyc_status")
  kycDocuments        Json          @default("{}") @map("kyc_documents")
  stellarPublicKey    String?       @map("stellar_public_key") @db.VarChar(56)
  // Passkey/Smart Wallet fields
  stellarContractId   String?       @map("stellar_contract_id") @db.VarChar(56)
  passkeyCredentialId String?       @map("passkey_credential_id") @db.Text
  passkeyPublicKey    Bytes?        @map("passkey_public_key")
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamp
  updatedAt           DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamp

  // Relations
  users     CompanyUser[]
  offers    Offer[]
  reminders PaymentReminder[]
  penalties CompanyPenalty[]

  @@index([email])
  @@index([cnpj])
  @@index([status])
  @@index([kycStatus])
  @@index([stellarPublicKey])
  @@index([stellarContractId])
  @@map("companies")
}

model CompanyUser {
  id               Int             @id @default(autoincrement())
  companyId        Int             @map("company_id")
  email            String          @unique @db.VarChar(255)
  passwordHash     String?         @map("password_hash") @db.VarChar(255)
  name             String          @db.VarChar(255)
  role             CompanyUserRole @default(user)
  isActive         Boolean         @default(true) @map("is_active")
  stellarPublicKey String?         @map("stellar_public_key") @db.VarChar(56)
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamp

  // Smart Wallet (Passkey Kit) fields
  stellarContractId   String? @map("stellar_contract_id") @db.VarChar(56)
  passkeyCredentialId String? @map("passkey_credential_id") @db.Text
  passkeyPublicKey    Bytes?  @map("passkey_public_key")

  // Email verification fields
  emailVerified           Boolean   @default(false) @map("email_verified")
  emailVerificationToken  String?   @map("email_verification_token") @db.VarChar(64)
  emailVerificationExpiry DateTime? @map("email_verification_expiry") @db.Timestamp

  // Relations
  company             Company                         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  webauthnCredentials CompanyUserWebauthnCredential[]
  ed25519Signers      CompanyUserEd25519Signer[]
  offers              Offer[]

  @@index([email])
  @@index([companyId])
  @@index([isActive])
  @@index([stellarPublicKey])
  @@index([stellarContractId])
  @@index([emailVerified])
  @@map("company_users")
}

model PlatformAdmin {
  id               Int               @id @default(autoincrement())
  email            String            @unique @db.VarChar(255)
  passwordHash     String            @map("password_hash") @db.VarChar(255)
  name             String            @db.VarChar(255)
  role             PlatformAdminRole @default(admin)
  isActive         Boolean           @default(true) @map("is_active")
  stellarPublicKey String?           @map("stellar_public_key") @db.VarChar(56)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamp
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamp
  mfaOtp           String?           @map("mfa_otp") @db.VarChar(6)
  mfaOtpExpires    DateTime?         @map("mfa_otp_expires") @db.Timestamp

  // Relations
  webauthnCredentials   PlatformAdminWebauthnCredential[]
  issuedTokens          Token[]
  reviewedOffers        Offer[]
  approvedDistributions TokenDistribution[]
  proposedTransactions  MultiSigTransaction[]

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@index([stellarPublicKey])
  @@map("platform_admins")
}

/// AdminAction — immutable audit log for platform-admin operations.
///
/// Append-only by convention. DB-level enforcement (revoke UPDATE/DELETE
/// for the application's Postgres role) should follow in a hardening
/// migration. Every requirePlatformAdmin / requireAdminRole route emits
/// one row via `adminAuditLog.service.js` on response finish.
///
/// `actorId` references `platform_admins.id` but is NOT declared as a Prisma
/// relation — audit log survives admin row deletion (which should be soft-only
/// anyway). `payloadHash` is sha256(request body) — we never store raw
/// payloads (PII, base64 blobs).
model AdminAction {
  id          String   @id @default(uuid())
  actorId     Int?     @map("actor_id")
  actorType   String?  @map("actor_type") @db.VarChar(50)
  actorRole   String?  @map("actor_role") @db.VarChar(50)
  action      String   @db.VarChar(255)
  targetType  String?  @map("target_type") @db.VarChar(50)
  targetId    String?  @map("target_id") @db.VarChar(255)
  payloadHash String?  @map("payload_hash") @db.VarChar(64)
  ip          String?  @db.VarChar(64)
  userAgent   String?  @map("user_agent") @db.VarChar(500)
  result      String   @db.VarChar(20)
  statusCode  Int?     @map("status_code")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([createdAt])
  @@map("admin_actions")
}

model Offer {
  id          Int    @id @default(autoincrement())
  companyId   Int    @map("company_id")
  requestedBy Int    @map("requested_by")
  assetCode   String @unique @map("asset_code") @db.VarChar(12)
  offerName   String @map("offer_name") @db.VarChar(255)
  description String @db.Text

  // Real Estate Collateral
  collateralType        String?  @default("real_estate") @map("collateral_type")
  collateralDescription String?  @map("collateral_description") @db.Text
  collateralValue       Decimal? @map("collateral_value") @db.Decimal(20, 2)
  collateralLTV         Decimal? @map("collateral_ltv") @db.Decimal(5, 2)
  totalSupply           Decimal  @map("total_supply") @db.Decimal(20, 7)
  unitPrice             Decimal  @default(1.0) @map("unit_price") @db.Decimal(20, 7)
  annualInterestRate    Decimal? @map("annual_interest_rate") @db.Decimal(10, 7)

  // Investor-facing yield rate. Company pays annualInterestRate, investor receives investorRate.
  // Spread (annualInterestRate - investorRate) → platform treasury revenue.
  // null = no spread (investorRate defaults to annualInterestRate).
  investorRate Decimal? @map("investor_rate") @db.Decimal(10, 7)

  // ── Phase 2: Asset Intelligence ──
  // Yield decomposition: investor sees where yield comes from (informational, no constraint)
  rentalYieldRate Decimal? @map("rental_yield_rate") @db.Decimal(10, 7)
  valueGrowthRate Decimal? @map("value_growth_rate") @db.Decimal(10, 7)

  // Location (for map pin + address display)
  latitude        Decimal? @map("latitude") @db.Decimal(10, 7)
  longitude       Decimal? @map("longitude") @db.Decimal(10, 7)
  locationAddress String?  @map("location_address") @db.VarChar(500)

  // Structured property metadata (polymorphic per asset type)
  assetMetadata Json?       @default("{}") @map("asset_metadata")
  // Phase 3: Asset lifecycle stage
  assetStage    AssetStage? @map("asset_stage")

  offerType           OfferType        @map("offer_type")
  offerRules          Json             @default("{}") @map("offer_rules")
  status              OfferStatus      @default(pending_review)
  rejectionReason     String?          @map("rejection_reason") @db.Text
  reviewedBy          Int?             @map("reviewed_by")
  reviewedAt          DateTime?        @map("reviewed_at") @db.Timestamp
  legalDocuments      Json             @default("{}") @map("legal_documents")
  dueDiligenceNotes   String?          @map("due_diligence_notes") @db.Text
  paymentType         PaymentType      @default(monthly) @map("payment_type")
  maturityDate        DateTime?        @map("maturity_date")
  bulletPaymentAmount Decimal?         @map("bullet_payment_amount") @db.Decimal(20, 7)
  paymentFrequency    Int              @default(1) @map("payment_frequency")
  paymentDay          Int              @default(1) @map("payment_day") // Day of month/period for payments (1-28)
  nextPaymentDue      DateTime?        @map("next_payment_due")
  lastPaymentDate     DateTime?        @map("last_payment_date")
  paymentDueStatus    PaymentDueStatus @default(current) @map("payment_due_status")

  // Atomic counter: incremented once per successful payment round.
  // Source of truth for maturity progress. Never derived from dates or records.
  periodicPaymentsCompleted Int @default(0) @map("periodic_payments_completed")

  // Token Lifecycle: Locked = AUTH_REQUIRED set on Issuer, all transfers require platform approval
  // When unlocked, the token is freely tradable on DEXes and on-chain balance becomes source of truth
  isTokenLocked   Boolean   @default(true) @map("is_token_locked")
  tokenUnlockedAt DateTime? @map("token_unlocked_at") @db.Timestamp

  // Soroban token_sale contract (set after offer approval + contract deploy)
  sorobanContractId String? @map("soroban_contract_id") @db.VarChar(56)
  sorobanInitStatus String? @map("soroban_init_status") @db.VarChar(20)
  sorobanInitError  String? @map("soroban_init_error") @db.Text

  // Soroban MaturitySettlement contract (for debt offers with maturity)
  // Deployed at offer approval. Handles atomic payout + token burn at maturity.
  sorobanSettlementContractId String? @map("soroban_settlement_contract_id") @db.VarChar(56)

  // Fixed processing fee per trade in USDC. Deducted from investor's trade amount → treasury.
  // 5.0 = $5 USDC per trade. 0 = no processing fee. Globally configurable via ConfigService.
  processingFee Decimal @default(5.0) @map("processing_fee") @db.Decimal(20, 7)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp

  // Relations
  company          Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requester        CompanyUser         @relation(fields: [requestedBy], references: [id], onDelete: Cascade)
  reviewer         PlatformAdmin?      @relation(fields: [reviewedBy], references: [id], onDelete: SetNull)
  tokens           Token[]
  distributions    TokenDistribution[]
  interestPayments InterestPayment[]
  investments      Investment[]
  reminders        PaymentReminder[]
  yieldPaymentJobs YieldPaymentJob[]

  @@index([companyId])
  @@index([status])
  @@index([assetCode])
  @@index([offerType])
  @@index([reviewedBy])
  @@index([paymentType])
  @@index([paymentDueStatus])
  @@index([nextPaymentDue])
  @@index([sorobanContractId])
  @@index([sorobanSettlementContractId])
  @@map("offers")
}

model Investment {
  id                 Int              @id @default(autoincrement())
  investorId         Int              @map("investor_id")
  offerId            Int?             @map("offer_id")
  assetCode          String           @map("asset_code") @db.VarChar(12)
  usdcAmount         Decimal          @map("usdc_amount") @db.Decimal(20, 7)
  tokenAmount        Decimal          @map("token_amount") @db.Decimal(20, 7)
  status             InvestmentStatus @default(pending_payment)
  usdcPaymentHash    String?          @map("usdc_payment_hash") @db.VarChar(64)
  distributionTxHash String?          @map("distribution_tx_hash") @db.VarChar(64)
  memo               String?          @db.VarChar(28)
  errorMessage       String?          @map("error_message") @db.Text
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamp
  updatedAt          DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamp

  // Relations
  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)
  offer    Offer?   @relation(fields: [offerId], references: [id], onDelete: SetNull)
  token    Token    @relation(fields: [assetCode], references: [assetCode], onDelete: Restrict)

  @@unique([investorId, offerId, usdcPaymentHash])
  @@index([investorId])
  @@index([offerId])
  @@index([status])
  @@index([assetCode])
  @@index([usdcPaymentHash])
  @@index([distributionTxHash])
  @@index([createdAt(sort: Desc)])
  // NOTE: A partial unique index exists in the DB but can't be expressed in Prisma DSL:
  //   UNIQUE (investor_id, offer_id) WHERE status IN ('pending_payment', 'trade_submitted')
  //   Applied via: prisma/migrations/20260308140000_.../migration.sql
  //   Purpose: Prevents race condition in concurrent investment submissions
  @@map("investments")
}

model InvestorWebauthnCredential {
  id           Int       @id @default(autoincrement())
  investorId   Int       @map("investor_id")
  credentialId String    @unique @map("credential_id") @db.Text
  publicKey    Bytes     @map("public_key")
  counter      BigInt    @default(0)
  deviceName   String?   @map("device_name") @db.VarChar(255)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp
  lastUsedAt   DateTime? @map("last_used_at") @db.Timestamp

  // Relations
  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@unique([investorId, credentialId])
  @@index([investorId])
  @@index([credentialId])
  @@map("investor_webauthn_credentials")
}

model CompanyUserWebauthnCredential {
  id            Int       @id @default(autoincrement())
  companyUserId Int       @map("company_user_id")
  credentialId  String    @unique @map("credential_id") @db.Text
  publicKey     Bytes     @map("public_key")
  counter       BigInt    @default(0)
  deviceName    String?   @map("device_name") @db.VarChar(255)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp
  lastUsedAt    DateTime? @map("last_used_at") @db.Timestamp

  // Relations
  companyUser CompanyUser @relation(fields: [companyUserId], references: [id], onDelete: Cascade)

  @@unique([companyUserId, credentialId])
  @@index([companyUserId])
  @@index([credentialId])
  @@map("company_user_webauthn_credentials")
}

