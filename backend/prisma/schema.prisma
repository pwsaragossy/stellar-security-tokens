// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum KYCStatus {
  pending
  approved
  rejected
}

enum CompanyStatus {
  pending
  approved
  suspended
  rejected
}

enum OfferStatus {
  pending_review
  under_review
  approved
  rejected
  active
  closed
}

enum PaymentType {
  monthly
  bullet
  quarterly
  semi_annual
  annual
}

enum OfferType {
  collateral
  sale
}

enum PaymentStatus {
  pending
  completed
  failed
}

enum PaymentDueStatus {
  current       // Payments up to date
  upcoming      // Payment due within 30 days
  due           // Payment due today
  overdue       // Past due but within grace period
  defaulted     // Past grace period, collateral liquidated
}

enum InvestmentStatus {
  pending_payment
  payment_received
  distributed
  failed
  cancelled
}

// ============================================
// CORE MODELS
// ============================================

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum CompanyUserRole {
  user
  admin
}

enum PlatformAdminRole {
  admin
  manager
  super_admin
}

// Models
model Investor {
  id               Int       @id @default(autoincrement())
  name             String    @db.VarChar(255)
  email            String    @unique @db.VarChar(255)
  document         String    @unique @db.VarChar(100)

  kycStatus        KYCStatus @default(pending) @map("kyc_status")
  passwordHash     String?   @map("password_hash") @db.VarChar(255)
  lastLogin        DateTime? @map("last_login") @db.Timestamp
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamp
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp

  // Smart Wallet (Passkey Kit) fields - REQUIRED for all new investors
  stellarContractId       String    @map("stellar_contract_id") @db.VarChar(56)
  passkeyCredentialId     String    @map("passkey_credential_id") @db.Text
  passkeyPublicKey        Bytes?    @map("passkey_public_key")

  // Email verification fields
  emailVerified           Boolean   @default(false) @map("email_verified")
  emailVerificationToken  String?   @map("email_verification_token") @db.VarChar(64)
  emailVerificationExpiry DateTime? @map("email_verification_expiry") @db.Timestamp

  // Relations
  tokenDistributions  TokenDistribution[]
  interestPayments    InterestPayment[]
  investments         Investment[]
  webauthnCredentials InvestorWebauthnCredential[]

  @@index([email])
  @@index([document])

  @@index([stellarContractId])
  @@index([emailVerified])
  @@index([kycStatus, createdAt(sort: Desc)])
  @@map("investors")
}

model Token {
  id                 Int      @id @default(autoincrement())
  assetCode          String   @unique @map("asset_code") @db.VarChar(12)
  issuerPublicKey    String   @map("issuer_public_key") @db.VarChar(56)
  totalSupply        Decimal  @map("total_supply") @db.Decimal(20, 7)
  description        String?  @db.Text
  annualInterestRate Decimal? @default(10.0) @map("annual_interest_rate") @db.Decimal(10, 7)
  offerId            Int?     @map("offer_id")
  issuedBy           Int?     @map("issued_by")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamp
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp

  // Relations
  offer            Offer?              @relation(fields: [offerId], references: [id], onDelete: SetNull)
  issuer           PlatformAdmin?      @relation(fields: [issuedBy], references: [id], onDelete: SetNull)
  distributions    TokenDistribution[]
  interestPayments InterestPayment[]
  investments      Investment[]

  @@index([assetCode])
  @@index([offerId])
  @@index([issuedBy])
  @@map("tokens")
}

model TokenDistribution {
  id              Int            @id @default(autoincrement())
  investorId      Int            @map("investor_id")
  assetCode       String         @map("asset_code") @db.VarChar(12)
  amount          Decimal        @db.Decimal(20, 7)
  transactionHash String         @map("transaction_hash") @db.VarChar(64)
  usdcPaymentHash String?        @map("usdc_payment_hash") @db.VarChar(64)
  offerId         Int?           @map("offer_id")
  memo            String?        @db.VarChar(28)
  approvalStatus  ApprovalStatus @default(pending) @map("approval_status")
  approvedBy      Int?           @map("approved_by")
  approvedAt      DateTime?      @map("approved_at") @db.Timestamp
  approvalNotes   String?        @map("approval_notes") @db.Text
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamp

  // Relations
  investor Investor       @relation(fields: [investorId], references: [id], onDelete: Cascade)
  token    Token          @relation(fields: [assetCode], references: [assetCode], onDelete: Cascade)
  offer    Offer?         @relation(fields: [offerId], references: [id], onDelete: SetNull)
  approver PlatformAdmin? @relation(fields: [approvedBy], references: [id], onDelete: SetNull)

  @@unique([transactionHash])
  @@unique([investorId, assetCode, usdcPaymentHash])
  @@index([investorId])
  @@index([assetCode])
  @@index([transactionHash])
  @@index([usdcPaymentHash])
  @@index([offerId])
  @@index([investorId, assetCode, createdAt(sort: Desc)])
  @@index([approvalStatus])
  @@index([approvedBy])
  @@map("token_distributions")
}

model InterestPayment {
  id              Int           @id @default(autoincrement())
  investorId      Int           @map("investor_id")
  assetCode       String        @map("asset_code") @db.VarChar(12)
  tokenBalance    Decimal       @map("token_balance") @db.Decimal(20, 7)
  interestRate    Decimal       @map("interest_rate") @db.Decimal(10, 7)
  interestAmount  Decimal       @map("interest_amount") @db.Decimal(20, 7)
  usdcAmount      Decimal       @map("usdc_amount") @db.Decimal(20, 7)
  transactionHash String        @map("transaction_hash") @db.VarChar(64)
  paymentDate     DateTime      @map("payment_date") @db.Date
  emailSent       Boolean       @default(false) @map("email_sent")
  emailSentAt     DateTime?     @map("email_sent_at") @db.Timestamp
  retryCount      Int           @default(0) @map("retry_count")
  status          PaymentStatus @default(pending)
  errorMessage    String?       @map("error_message") @db.Text
  offerId         Int?          @map("offer_id")
  paymentType     PaymentType   @default(monthly) @map("payment_type")
  isBulletPayment Boolean       @default(false) @map("is_bullet_payment")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamp

  // Relations
  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)
  token    Token    @relation(fields: [assetCode], references: [assetCode], onDelete: Cascade)
  offer    Offer?   @relation(fields: [offerId], references: [id], onDelete: SetNull)

  @@unique([investorId, assetCode, paymentDate, transactionHash])
  @@index([investorId])
  @@index([assetCode])
  @@index([paymentDate])
  @@index([status])
  @@index([offerId])
  @@index([investorId, assetCode, paymentDate(sort: Desc)])
  @@index([investorId, paymentDate])
  @@index([paymentDate(sort: Desc), assetCode])
  @@index([paymentType])
  @@map("interest_payments")
}

model Company {
  id                  Int           @id @default(autoincrement())
  name                String        @db.VarChar(255)
  cnpj                String?       @unique @db.VarChar(18)  // Optional - collected during KYC
  email               String        @unique @db.VarChar(255)
  emailVerified       Boolean       @default(false) @map("email_verified")
  legalRepresentative String?       @map("legal_representative") @db.VarChar(255) // Optional - collected during KYC
  address             String?       @db.Text
  phone               String?       @db.VarChar(20)
  status              CompanyStatus @default(pending)
  kycStatus           KYCStatus     @default(pending) @map("kyc_status")
  kycDocuments        Json          @default("{}") @map("kyc_documents")
  stellarPublicKey    String?       @map("stellar_public_key") @db.VarChar(56)
  // Passkey/Smart Wallet fields
  stellarContractId   String?       @map("stellar_contract_id") @db.VarChar(56)
  passkeyCredentialId String?       @map("passkey_credential_id") @db.Text
  passkeyPublicKey    Bytes?        @map("passkey_public_key")
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamp
  updatedAt           DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamp

  // Relations
  users     CompanyUser[]
  offers    Offer[]
  reminders PaymentReminder[]
  penalties CompanyPenalty[]

  @@index([email])
  @@index([cnpj])
  @@index([status])
  @@index([kycStatus])
  @@index([stellarPublicKey])
  @@index([stellarContractId])
  @@map("companies")
}

model CompanyUser {
  id               Int             @id @default(autoincrement())
  companyId        Int             @map("company_id")
  email            String          @unique @db.VarChar(255)
  passwordHash     String?         @map("password_hash") @db.VarChar(255)
  name             String          @db.VarChar(255)
  role             CompanyUserRole @default(user)
  isActive         Boolean         @default(true) @map("is_active")
  stellarPublicKey String?         @map("stellar_public_key") @db.VarChar(56)
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamp

  // Smart Wallet (Passkey Kit) fields
  stellarContractId       String?   @map("stellar_contract_id") @db.VarChar(56)
  passkeyCredentialId     String?   @map("passkey_credential_id") @db.Text
  passkeyPublicKey        Bytes?    @map("passkey_public_key")

  // Email verification fields
  emailVerified           Boolean   @default(false) @map("email_verified")
  emailVerificationToken  String?   @map("email_verification_token") @db.VarChar(64)
  emailVerificationExpiry DateTime? @map("email_verification_expiry") @db.Timestamp

  // Relations
  company             Company                         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  webauthnCredentials CompanyUserWebauthnCredential[]
  offers              Offer[]

  @@index([email])
  @@index([companyId])
  @@index([isActive])
  @@index([stellarPublicKey])
  @@index([stellarContractId])
  @@index([emailVerified])
  @@map("company_users")
}

model PlatformAdmin {
  id               Int               @id @default(autoincrement())
  email            String            @unique @db.VarChar(255)
  passwordHash     String            @map("password_hash") @db.VarChar(255)
  name             String            @db.VarChar(255)
  role             PlatformAdminRole @default(admin)
  isActive         Boolean           @default(true) @map("is_active")
  stellarPublicKey String?           @map("stellar_public_key") @db.VarChar(56)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamp
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamp

  // Relations
  webauthnCredentials   PlatformAdminWebauthnCredential[]
  issuedTokens          Token[]
  reviewedOffers        Offer[]
  approvedDistributions TokenDistribution[]
  proposedTransactions  MultiSigTransaction[]

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@index([stellarPublicKey])
  @@map("platform_admins")
}

model Offer {
  id                  Int         @id @default(autoincrement())
  companyId           Int         @map("company_id")
  requestedBy         Int         @map("requested_by")
  assetCode           String      @unique @map("asset_code") @db.VarChar(12)
  offerName           String      @map("offer_name") @db.VarChar(255)
  description         String      @db.Text

  // Real Estate Collateral
  collateralType        String?   @default("real_estate") @map("collateral_type")
  collateralDescription String?   @map("collateral_description") @db.Text
  collateralValue       Decimal?  @map("collateral_value") @db.Decimal(20, 2)
  collateralLTV         Decimal?  @map("collateral_ltv") @db.Decimal(5, 2)
  totalSupply         Decimal     @map("total_supply") @db.Decimal(20, 7)
  annualInterestRate  Decimal?    @map("annual_interest_rate") @db.Decimal(10, 7)
  offerType           OfferType   @map("offer_type")
  offerRules          Json        @default("{}") @map("offer_rules")
  status              OfferStatus @default(pending_review)
  rejectionReason     String?     @map("rejection_reason") @db.Text
  reviewedBy          Int?        @map("reviewed_by")
  reviewedAt          DateTime?   @map("reviewed_at") @db.Timestamp
  legalDocuments      Json        @default("{}") @map("legal_documents")
  dueDiligenceNotes   String?     @map("due_diligence_notes") @db.Text
  paymentType         PaymentType @default(monthly) @map("payment_type")
  maturityDate        DateTime?   @map("maturity_date")
  bulletPaymentAmount Decimal?    @map("bullet_payment_amount") @db.Decimal(20, 7)
  paymentFrequency    Int         @default(1) @map("payment_frequency")
  paymentDay          Int         @default(1) @map("payment_day") // Day of month/period for payments (1-28)
  nextPaymentDue      DateTime?   @map("next_payment_due")
  lastPaymentDate     DateTime?   @map("last_payment_date")
  paymentDueStatus    PaymentDueStatus @default(current) @map("payment_due_status")
  createdAt           DateTime    @default(now()) @map("created_at") @db.Timestamp
  updatedAt           DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamp

  // Relations
  company          Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requester        CompanyUser         @relation(fields: [requestedBy], references: [id], onDelete: Cascade)
  reviewer         PlatformAdmin?      @relation(fields: [reviewedBy], references: [id], onDelete: SetNull)
  tokens           Token[]
  distributions    TokenDistribution[]
  interestPayments InterestPayment[]
  investments      Investment[]
  reminders        PaymentReminder[]

  @@index([companyId])
  @@index([status])
  @@index([assetCode])
  @@index([offerType])
  @@index([reviewedBy])
  @@index([paymentType])
  @@index([paymentDueStatus])
  @@index([nextPaymentDue])
  @@map("offers")
}

model Investment {
  id                 Int              @id @default(autoincrement())
  investorId         Int              @map("investor_id")
  offerId            Int?             @map("offer_id")
  assetCode          String           @map("asset_code") @db.VarChar(12)
  usdcAmount         Decimal          @map("usdc_amount") @db.Decimal(20, 7)
  tokenAmount        Decimal          @map("token_amount") @db.Decimal(20, 7)
  status             InvestmentStatus @default(pending_payment)
  usdcPaymentHash    String?          @map("usdc_payment_hash") @db.VarChar(64)
  distributionTxHash String?          @map("distribution_tx_hash") @db.VarChar(64)
  memo               String?          @db.VarChar(28)
  errorMessage       String?          @map("error_message") @db.Text
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamp
  updatedAt          DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamp

  // Relations
  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)
  offer    Offer?   @relation(fields: [offerId], references: [id], onDelete: SetNull)
  token    Token    @relation(fields: [assetCode], references: [assetCode], onDelete: Restrict)

  @@unique([investorId, offerId, usdcPaymentHash])
  @@index([investorId])
  @@index([offerId])
  @@index([status])
  @@index([assetCode])
  @@index([usdcPaymentHash])
  @@index([distributionTxHash])
  @@index([createdAt(sort: Desc)])
  @@map("investments")
}

model InvestorWebauthnCredential {
  id           Int       @id @default(autoincrement())
  investorId   Int       @map("investor_id")
  credentialId String    @unique @map("credential_id") @db.Text
  publicKey    Bytes     @map("public_key")
  counter      BigInt    @default(0)
  deviceName   String?   @map("device_name") @db.VarChar(255)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp
  lastUsedAt   DateTime? @map("last_used_at") @db.Timestamp

  // Relations
  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@unique([investorId, credentialId])
  @@index([investorId])
  @@index([credentialId])
  @@map("investor_webauthn_credentials")
}

model CompanyUserWebauthnCredential {
  id            Int       @id @default(autoincrement())
  companyUserId Int       @map("company_user_id")
  credentialId  String    @unique @map("credential_id") @db.Text
  publicKey     Bytes     @map("public_key")
  counter       BigInt    @default(0)
  deviceName    String?   @map("device_name") @db.VarChar(255)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp
  lastUsedAt    DateTime? @map("last_used_at") @db.Timestamp

  // Relations
  companyUser CompanyUser @relation(fields: [companyUserId], references: [id], onDelete: Cascade)

  @@unique([companyUserId, credentialId])
  @@index([companyUserId])
  @@index([credentialId])
  @@map("company_user_webauthn_credentials")
}

model PlatformAdminWebauthnCredential {
  id              Int       @id @default(autoincrement())
  platformAdminId Int       @map("platform_admin_id")
  credentialId    String    @unique @map("credential_id") @db.Text
  publicKey       Bytes     @map("public_key")
  counter         BigInt    @default(0)
  deviceName      String?   @map("device_name") @db.VarChar(255)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp
  lastUsedAt      DateTime? @map("last_used_at") @db.Timestamp

  // Relations
  platformAdmin PlatformAdmin @relation(fields: [platformAdminId], references: [id], onDelete: Cascade)

  @@unique([platformAdminId, credentialId])
  @@index([platformAdminId])
  @@index([credentialId])
  @@map("platform_admin_webauthn_credentials")
}

model SystemConfig {
  key         String   @id @db.VarChar(50)
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp

  @@map("system_config")
}

model FeeLog {
  id              Int      @id @default(autoincrement())
  amount          Decimal  @db.Decimal(20, 7)
  assetCode       String   @map("asset_code") @db.VarChar(12)
  category        String   @db.VarChar(50) // ISSUANCE, WITHDRAWAL, DIVIDEND
  sourceId        Int?     @map("source_id")
  description     String?  @db.Text
  transactionHash String?  @map("transaction_hash") @db.VarChar(64)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp

  @@index([category])
  @@index([createdAt])
  @@map("fee_logs")
}

enum MultiSigTxStatus {
  pending
  partially_signed
  ready
  submitted
  executed
  rejected
  failed
  expired
}

enum MultiSigOperationType {
  token_issue
  token_distribute
  freeze_account
  clawback
  treasury_payment
  trustline_auth
  account_setup
  other
}

model MultiSigTransaction {
  id                 Int                   @id @default(autoincrement())
  operationType      MultiSigOperationType @default(other) @map("operation_type")
  xdr                String                @db.Text
  networkPassphrase  String                @map("network_passphrase") @db.VarChar(100)
  description        String?               @db.VarChar(255)
  status             MultiSigTxStatus      @default(pending)
  
  // Signers configuration  
  requiredSigners    String[]              @map("required_signers") // Array of public keys
  thresholdRequired  Int                   @default(1) @map("threshold_required")
  collectedSignatures Json                 @default("{}") @map("collected_signatures") // { publicKey: signatureBase64 }
  
  // Tracking
  initiatorId        Int?                  @map("initiator_id")
  initiatorType      String?               @map("initiator_type") @db.VarChar(50) // 'platform_admin', 'company_user'
  
  // Metadata for context
  metadata           Json                  @default("{}") // offerId, investorId, amount, assetCode, etc.
  
  // Lifecycle
  expiresAt          DateTime              @map("expires_at") @db.Timestamp
  submittedAt        DateTime?             @map("submitted_at") @db.Timestamp
  txHash             String?               @map("tx_hash") @db.VarChar(64)
  ledger             Int?
  errorMessage       String?               @map("error_message") @db.Text
  
  createdAt          DateTime              @default(now()) @map("created_at") @db.Timestamp
  updatedAt          DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamp

  initiator          PlatformAdmin?        @relation(fields: [initiatorId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([operationType])
  @@index([initiatorId])
  @@index([expiresAt])
  @@index([txHash])
  @@map("multisig_transactions")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  userType  String   @map("user_type") // 'investor', 'company_user', 'platform_admin'
  type      String   // 'info', 'success', 'warning', 'error'
  title     String   @db.VarChar(255)
  message   String   @db.Text
  actionLink String? @map("action_link") @db.VarChar(255)
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp

  @@index([userId, userType])
  @@index([isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

// Payment reminder tracking for company payments
model PaymentReminder {
  id              Int       @id @default(autoincrement())
  offerId         Int       @map("offer_id")
  companyId       Int       @map("company_id")
  reminderType    String    @map("reminder_type") // '30_day', '21_day', '14_day', '7_day', '3_day', '1_day', 'due_day', 'overdue'
  dueDate         DateTime  @map("due_date") @db.Date
  amountDue       Decimal   @map("amount_due") @db.Decimal(20, 7)
  sentAt          DateTime  @default(now()) @map("sent_at") @db.Timestamp
  sentVia         String    @default("email") @map("sent_via") // 'email', 'notification', 'both'
  acknowledged    Boolean   @default(false)
  acknowledgedAt  DateTime? @map("acknowledged_at") @db.Timestamp

  // Relations
  offer           Offer     @relation(fields: [offerId], references: [id], onDelete: Cascade)
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([offerId, reminderType, dueDate])
  @@index([offerId])
  @@index([companyId])
  @@index([dueDate])
  @@index([reminderType])
  @@map("payment_reminders")
}

// Company penalties for late/defaulted payments
model CompanyPenalty {
  id              Int       @id @default(autoincrement())
  companyId       Int       @map("company_id")
  offerId         Int       @map("offer_id")
  penaltyType     String    @map("penalty_type") // 'late_fee', 'default_fee', 'platform_ban'
  description     String    @db.Text
  amount          Decimal?  @db.Decimal(20, 7) // In USDC
  percentageRate  Decimal?  @map("percentage_rate") @db.Decimal(5, 4) // e.g., 0.005 for 0.5% per day
  daysLate        Int?      @map("days_late")
  status          String    @default("pending") // 'pending', 'paid', 'waived', 'enforced'
  enforcedAt      DateTime? @map("enforced_at") @db.Timestamp
  paidAt          DateTime? @map("paid_at") @db.Timestamp
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp

  // Relations
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([offerId])
  @@index([status])
  @@index([penaltyType])
  @@map("company_penalties")
}
