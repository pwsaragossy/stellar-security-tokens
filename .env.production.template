# =============================================================================
# Radox Platform — Production Environment Variables
# =============================================================================
# Copy this file to .env.production and fill in ALL values.
#   cp .env.production.template .env.production
#   chmod 600 .env.production
#
# Start services:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml \
#     --env-file .env.production up -d --build
# =============================================================================

# --- Database (PostgreSQL) ---------------------------------------------------
POSTGRES_DB=stellar_tokens
POSTGRES_USER=stellar_prod
POSTGRES_PASSWORD=           # openssl rand -base64 24

# --- Redis --------------------------------------------------------------------
REDIS_PASSWORD=              # openssl rand -base64 16

# --- Security -----------------------------------------------------------------
JWT_SECRET=                  # openssl rand -hex 32
API_KEY=                     # openssl rand -hex 16

# --- Key Management -----------------------------------------------------------
# multisig = Freighter/Ledger client-side signing (REQUIRED for production)
# env      = server-side signing (development only)
KEY_MANAGEMENT_MODE=multisig

# --- Stellar Network ----------------------------------------------------------
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HOME_DOMAIN=radox.net

# --- Stellar Accounts (PUBLIC KEYS ONLY — G...) ------------------------------
# Secret keys are NEVER stored here. Admin signing via Freighter/Ledger.
# Operations hot wallet key → /root/.secrets/operations_key (Docker Secrets)
ISSUER_PUBLIC_KEY=
DISTRIBUTOR_PUBLIC_KEY=
OPERATIONS_PUBLIC_KEY=
TREASURY_PUBLIC_KEY=

# --- USDC (auto-detected on testnet, set explicitly for mainnet) -------------
# USDC_ISSUER=GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN

# --- Soroban Asset Contracts (SAC IDs) ----------------------------------------
# Testnet defaults are in docker-compose.yml. Override here for mainnet.
XLM_SAC_CONTRACT_ID=
USDC_SAC_CONTRACT_ID=

# --- Smart Wallets (OpenZeppelin Stellar Channels) ----------------------------
# API key from https://channels.openzeppelin.com/testnet/gen (testnet)
# or https://channels.openzeppelin.com/gen (mainnet)
CHANNELS_API_KEY=              # Required for fee-sponsored transactions
# ACCOUNT_WASM_HASH for the smart account contract (from smart-account-kit docs)
ACCOUNT_WASM_HASH=
# Verifier contract addresses (pre-deployed on testnet/mainnet by OpenZeppelin)
WEBAUTHN_VERIFIER_ADDRESS=
ED25519_VERIFIER_ADDRESS=

# --- Soroban Sale -------------------------------------------------------------
# Kill switch — set to true ONLY when ready to accept investments
ENABLE_SOROBAN_SALE=false
SALE_WASM_HASH=              # WASM hash of the deployed sale contract (v6, fixedFee model)

# --- Soroban Settlement (Bullet Maturity) -------------------------------------
# WASM hash for the MaturitySettlement contract (hex, 64 chars)
# Required for bullet maturity payouts — without this, no settlement can be deployed
SETTLEMENT_WASM_HASH=

# --- WebAuthn / Passkeys ------------------------------------------------------
WEBAUTHN_RP_ID=radox.net
WEBAUTHN_ORIGIN=https://app.radox.net

# --- Frontend URL (used in emails, redirects) ---------------------------------
FRONTEND_URL=https://app.radox.net

# --- Email (Resend HTTP API — port 443, bypasses DO SMTP block) ---------------
RESEND_API_KEY=
EMAIL_FROM=Radox <noreply@mail.radox.net>

# --- IPFS / Pinata ------------------------------------------------------------
PINATA_JWT=

# --- Payment Scheduler --------------------------------------------------------
ENABLE_AUTO_PAYMENTS=true

# --- Vite Build-Time Overrides (frontend bundle) ------------------------------
# Defaults in docker-compose.prod.yml point to testnet.
# Override here when migrating to mainnet:
# STELLAR_NETWORK=public
# STELLAR_HORIZON_URL=https://horizon.stellar.org
# SOROBAN_RPC_URL=https://mainnet.sorobanrpc.com
# VITE_STELLAR_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015
